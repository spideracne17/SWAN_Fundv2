# PocketBase API URL (pockethost.io or local dev)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# Charles Schwab API (get from developer.schwab.com)
VITE_SCHWAB_CLIENT_ID=your_app_key_here
VITE_SCHWAB_CLIENT_SECRET=your_app_secret_here
VITE_SCHWAB_CALLBACK_URL=https://127.0.0.1:5173/callback

# Market data proxy URL (optional — set up a CORS proxy or server-side function
# that returns JSON with: vix_level, spx_price, spx_50dma, spx_200dma, iv_rank)
# VITE_MARKET_DATA_URL=http://localhost:3001/api/market-data
