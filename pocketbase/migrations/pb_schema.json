      {
        "name": "account_type",
        "type": "select",
        "required": true,
        "options": { "maxSelect": 1, "values": ["taxable", "roth_ira", "traditional_ira"] }
      },
      {
        "name": "account_number_last4",
        "type": "text",
        "required": true,
        "options": { "min": 4, "max": 4, "pattern": "^\\d{4}$" }
      },
      {
